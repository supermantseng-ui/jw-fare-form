<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    :root {
      --ink:#1c2430; --ink-soft:#5b6472; --navy:#1e3a5f; --navy-deep:#152a45;
      --accent:#b8863f; --accent-soft:#f3e8d5;
      --bg:#f7f5f0; --surface:#ffffff; --border:#e6e1d6;
      --danger:#b3432f; --danger-bg:#fbeeeb; --ok:#2f7d52; --ok-bg:#eaf6ee;
      --radius:10px;
    }
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, "PingFang TC", "Microsoft JhengHei", sans-serif;
      margin:0; padding:0 0 40px; background:var(--bg); color:var(--ink);
    }
    header.top {
      background: linear-gradient(135deg, var(--navy) 0%, var(--navy-deep) 100%);
      color:#fff; padding:22px 18px 20px; margin-bottom:18px;
    }
    header.top .eyebrow { font-size:11px; letter-spacing:.12em; color:#c7d3e0; text-transform:uppercase; margin:0 0 6px; }
    header.top h2 { margin:0 0 6px; font-size:20px; font-weight:600; }
    header.top .sub { color:#aebdd0; font-size:12.5px; margin:0; }
    .wrap { padding:0 16px; max-width:520px; margin:0 auto; }
    section {
      background:var(--surface); border:1px solid var(--border); border-radius:var(--radius);
      padding:16px 18px; margin-bottom:14px; box-shadow:0 1px 2px rgba(28,36,48,.04);
    }
    label { font-size:12px; color:var(--ink-soft); display:block; margin-bottom:4px; font-weight:500; }
    input { width:100%; padding:9px 10px; border:1px solid var(--border); border-radius:7px; font-size:14px; margin-bottom:10px; }
    button { background:var(--navy); color:#fff; border:none; border-radius:8px; padding:11px 16px; font-size:13.5px; font-weight:600; cursor:pointer; width:100%; }
    button:disabled { opacity:.45; cursor:not-allowed; }
    .grid2 { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
    .info-row { display:flex; justify-content:space-between; padding:7px 0; border-bottom:1px solid var(--border); font-size:13.5px; }
    .info-row:last-child { border-bottom:none; }
    .info-row .k { color:var(--ink-soft); }
    .summary-line { white-space:pre-wrap; font-size:13px; background:var(--bg); padding:10px 12px; border-radius:8px; margin:8px 0; }
    .thumbs { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin:10px 0; }
    .thumbs a { display:block; }
    .thumbs img { width:100%; height:140px; object-fit:cover; border-radius:8px; border:1px solid var(--border); }
    .err-box { background:var(--danger-bg); border:1px solid #f0c9c0; color:var(--danger); padding:10px 12px; border-radius:8px; font-size:13px; margin-bottom:10px; }
    .ok-box { background:var(--ok-bg); border:1px solid #bfe4cc; color:var(--ok); padding:10px 12px; border-radius:8px; font-size:13px; margin-bottom:10px; }
    .reviewed-tag { display:inline-block; font-size:11px; padding:3px 9px; border-radius:20px; background:var(--ok-bg); color:var(--ok); font-weight:600; }
  </style>
</head>
<body>
  <header class="top">
    <div class="wrap" style="padding:0;">
      <p class="eyebrow">嘉威會計師事務所 · 財會審核</p>
      <h2>交通費用單據查詢</h2>
      <p class="sub">輸入工號驗證身分後，查詢單號即可看到明細與憑證，確認後填寫匯款日期。</p>
    </div>
  </header>

  <div class="wrap">
    <section>
      <label>您的工號</label>
      <input id="reviewerId" type="text" placeholder="用來驗證身分">
      <label>單據號碼</label>
      <input id="subjectId" type="text" placeholder="例如 JW-farev2-20260707-3">
      <button id="queryBtn">查詢</button>
      <div id="queryMsg"></div>
    </section>

    <section id="resultSection" style="display:none;">
      <div id="reviewedBanner"></div>
      <div class="info-row"><span class="k">申請人</span><span id="r_applicant"></span></div>
      <div class="info-row"><span class="k">送出時間</span><span id="r_time"></span></div>
      <div class="info-row"><span class="k">總額</span><span id="r_total" style="font-weight:600;"></span></div>
      <p style="font-size:12px;color:var(--ink-soft);margin:12px 0 4px;">明細摘要</p>
      <div class="summary-line" id="r_summary"></div>
      <p style="font-size:12px;color:var(--ink-soft);margin:12px 0 4px;">憑證縮圖（點擊可放大原圖）</p>
      <div class="thumbs" id="r_thumbs"></div>

      <label style="margin-top:12px;">匯款日期</label>
      <input id="remitDate" type="date">
      <button id="saveBtn">確認並儲存匯款日期</button>
      <div id="saveMsg"></div>
    </section>
  </div>

<script>
  // ⚠️ 部署後請換成實際的GAS API網址
  const GAS_URL = 'https://script.google.com/macros/s/AKfycbznsIOeAci4sX9M4veaases2srjEALVl2vnd4MfRTM8S02t3DLJHTjPGLXiFUAQAwH-JQ/exec';

  function escapeHtml(str) {
    return String(str == null ? '' : str).replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    }[c]));
  }

  function callApi(action, data) {
    return fetch(GAS_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'text/plain;charset=utf-8' },
      body: JSON.stringify(Object.assign({ action: action }, data)),
    }).then((r) => r.json());
  }

  // Google Drive 分享連結轉成可直接顯示縮圖的網址
  function toThumbUrl(driveUrl) {
    const m = driveUrl.match(/\/d\/([a-zA-Z0-9_-]+)/);
    if (!m) return null;
    return 'https://drive.google.com/thumbnail?id=' + m[1] + '&sz=w500';
  }

  let currentSubjectId = null;

  document.getElementById('queryBtn').addEventListener('click', () => {
    const reviewerId = document.getElementById('reviewerId').value.trim();
    const subjectId = document.getElementById('subjectId').value.trim();
    const msg = document.getElementById('queryMsg');
    msg.innerHTML = '';
    document.getElementById('resultSection').style.display = 'none';

    if (!reviewerId) { msg.innerHTML = '<div class="err-box">請輸入工號</div>'; return; }
    if (!subjectId) { msg.innerHTML = '<div class="err-box">請輸入單號</div>'; return; }

    callApi('queryDocument', { subjectId, reviewerId }).then((res) => {
      if (!res.ok) {
        msg.innerHTML = '<div class="err-box">' + escapeHtml(res.reason) + '</div>';
        return;
      }
      currentSubjectId = res.subjectId;
      document.getElementById('resultSection').style.display = 'block';
      document.getElementById('r_applicant').textContent = res.applicantName + '（' + res.applicantId + '）';
      document.getElementById('r_time').textContent = res.submitTime ? new Date(res.submitTime).toLocaleString('zh-TW') : '';
      document.getElementById('r_total').textContent = 'NT$ ' + Number(res.total).toLocaleString();
      document.getElementById('r_summary').textContent = res.summary;

      const thumbs = document.getElementById('r_thumbs');
      thumbs.innerHTML = res.links.map((link) => {
        const thumbUrl = toThumbUrl(link);
        if (!thumbUrl) return '';
        return '<a href="' + link + '" target="_blank"><img src="' + thumbUrl + '" loading="lazy"></a>';
      }).join('') || '<p style="font-size:12px;color:var(--ink-soft);">（這張單沒有附件連結）</p>';

      const banner = document.getElementById('reviewedBanner');
      if (res.remittanceDate) {
        banner.innerHTML = '<span class="reviewed-tag">已於 ' + new Date(res.remittanceDate).toLocaleDateString('zh-TW') +
          ' 由工號' + escapeHtml(res.reviewedBy) + ' 確認匯款</span><div style="height:10px;"></div>';
        document.getElementById('remitDate').value = new Date(res.remittanceDate).toISOString().slice(0, 10);
      } else {
        banner.innerHTML = '';
        document.getElementById('remitDate').value = '';
      }
    }).catch((err) => {
      msg.innerHTML = '<div class="err-box">呼叫失敗：' + escapeHtml(err.message) + '</div>';
    });
  });

  document.getElementById('saveBtn').addEventListener('click', () => {
    const reviewerId = document.getElementById('reviewerId').value.trim();
    const remitDate = document.getElementById('remitDate').value;
    const msg = document.getElementById('saveMsg');
    msg.innerHTML = '';

    if (!remitDate) { msg.innerHTML = '<div class="err-box">請選擇匯款日期</div>'; return; }
    if (!currentSubjectId) { msg.innerHTML = '<div class="err-box">請先查詢單據</div>'; return; }

    callApi('saveRemittanceDate', { subjectId: currentSubjectId, reviewerId, remittanceDate: remitDate }).then((res) => {
      if (res.ok) {
        msg.innerHTML = '<div class="ok-box">已儲存，麻煩回到BPM手動點選該單據，將流程推進到下一關。</div>';
      } else {
        msg.innerHTML = '<div class="err-box">' + escapeHtml(res.reason) + '</div>';
      }
    }).catch((err) => {
      msg.innerHTML = '<div class="err-box">呼叫失敗：' + escapeHtml(err.message) + '</div>';
    });
  });
</script>
</body>
</html>
